# API base (must end with /api). Defaults to /api (Vite dev proxy → backend-admin :3000).
# Legacy: VITE_API_BASE_URL is also read if VITE_API_URL is unset.
# VITE_API_URL=http://localhost:3000/api
# VITE_API_URL=https://your-production-host.com/api

# Admin email (display only for mock sign-in)
VITE_ADMIN_EMAIL=admin@elara.style

# Default email prefilled on the sign-in form (must match an admin user in MongoDB)
# VITE_ADMIN_EMAIL=admin@elara.style

# Vite proxies /api → this URL. Backend must be running or login/API calls get ECONNREFUSED.
# VITE_PROXY_TARGET=http://127.0.0.1:3000

# Firebase Web (client) — from Firebase console → Project settings → Your apps → Web app
# Used by src/services/firebaseMessaging.ts and to generate public/firebase-messaging-sw.js (predev/prebuild).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_VAPID_KEY=
